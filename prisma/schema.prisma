generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// --- КОРИСТУВАЧІ ТА КЛАСИ ---
model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  firstName    String
  lastName     String
  role         String   @default("STUDENT") // SQLite не вміє enum, тому String

  // Для учнів: прив'язка до класу
  classId      String?
  class        Class?   @relation(fields: [classId], references: [id])

  // Зв'язки
  taughtSubjects    TeacherSubject[]
  enrolledSubjects  StudentSubject[]
  givenGrades       Gradebook[]      @relation("TeacherGrades")
  receivedGrades    Gradebook[]      @relation("StudentGrades")
  achievements      Achievement[]

  createdAt    DateTime @default(now())
}

model Class {
  id       String   @id @default(uuid())
  name     String   @unique
  students User[]
  schedule Schedule[]
}

// --- ПРЕДМЕТИ ---
model Subject {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?

  teachers    TeacherSubject[]
  students    StudentSubject[]
  grades      Gradebook[]
  schedule    Schedule[]
  materials   Material[]
  quizzes     Quiz[]
}

model TeacherSubject {
  id        String  @id @default(uuid())
  teacherId String
  subjectId String

  teacher   User    @relation(fields: [teacherId], references: [id])
  subject   Subject @relation(fields: [subjectId], references: [id])

  @@unique([teacherId, subjectId])
}

model StudentSubject {
  id        String  @id @default(uuid())
  studentId String
  subjectId String

  student   User    @relation(fields: [studentId], references: [id])
  subject   Subject @relation(fields: [subjectId], references: [id])

  @@unique([studentId, subjectId])
}

// --- ЖУРНАЛ ОЦІНОК ---
model Gradebook {
  id          String     @id @default(uuid())
  studentId   String
  teacherId   String
  subjectId   String
  date        DateTime
  
  grade       Int?
  attendance  String     @default("PRESENT") // SQLite не вміє enum, тому String

  student     User       @relation("StudentGrades", fields: [studentId], references: [id])
  teacher     User       @relation("TeacherGrades", fields: [teacherId], references: [id])
  subject     Subject    @relation(fields: [subjectId], references: [id])

  @@unique([studentId, subjectId, date])
}

model Schedule {
  id          String   @id @default(uuid())
  classId     String
  subjectId   String
  startTime   DateTime
  endTime     DateTime

  class       Class    @relation(fields: [classId], references: [id])
  subject     Subject  @relation(fields: [subjectId], references: [id])
}

model Achievement {
  id          String   @id @default(uuid())
  userId      String
  title       String
  date        DateTime
  user        User     @relation(fields: [userId], references: [id])
}

model Material {
  id          String   @id @default(uuid())
  subjectId   String
  title       String
  type        String
  url         String
  subject     Subject  @relation(fields: [subjectId], references: [id])
}

model Quiz {
  id          String     @id @default(uuid())
  subjectId   String
  title       String
  subject     Subject    @relation(fields: [subjectId], references: [id])
  questions   Question[]
}

model Question {
  id          String   @id @default(uuid())
  quizId      String
  text        String
  isMultiple  Boolean
  quiz        Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  answers     Answer[]
}

model Answer {
  id          String   @id @default(uuid())
  questionId  String
  text        String
  isCorrect   Boolean
  question    Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
}