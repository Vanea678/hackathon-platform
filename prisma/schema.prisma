generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// 1. Користувачі (Організатор, Журі, Команда)
model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  fullName     String
  role         String   @default("TEAM") // 'ADMIN', 'TEAM', 'JURY'

  evaluations  Evaluation[] // Для журі
  createdAt    DateTime @default(now())
}

// 2. Турніри
model Tournament {
  id             String   @id @default(uuid())
  title          String
  description    String
  status         String   @default("DRAFT") // 'DRAFT', 'REGISTRATION', 'RUNNING', 'FINISHED'
  
  startDate      DateTime
  regEndDate     DateTime

  teams          Team[]
  tasks          Task[]
}

// 3. Команди (Реєстрація)
model Team {
  id              String   @id @default(uuid())
  name            String
  tournamentId    String
  captainEmail    String   @unique
  
  membersList     String   @default("[]") // Список учасників команди
  
  tournament      Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  submissions     Submission[]
}

// 4. Завдання (Раунди)
model Task {
  id                  String   @id @default(uuid())
  tournamentId        String
  title               String
  description         String
  mustHaveChecklist   String   @default("[]") 
  
  deadline            DateTime
  
  tournament          Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  submissions         Submission[]
}

// 5. Сабміти (Подані роботи)
model Submission {
  id              String   @id @default(uuid())
  teamId          String
  taskId          String
  
  githubUrl       String
  videoUrl        String
  description     String?
  
  team            Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  task            Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  evaluations     Evaluation[]

  @@unique([teamId, taskId]) 
}

// 6. Оцінки Журі
model Evaluation {
  id              String   @id @default(uuid())
  submissionId    String
  juryId          String
  
  scoreTech       Int?     // Якість коду (0-100)
  scoreFunc       Int?     // Функціональність (0-100)
  scoreUI         Int?     // UI/UX (0-100)
  totalScore      Float?
  comment         String?
  
  submission      Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  jury            User       @relation(fields: [juryId], references: [id], onDelete: Cascade)

  @@unique([submissionId, juryId]) 
}