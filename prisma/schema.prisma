generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// 1. Користувачі (Організатор, Журі, Команда)
model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  fullName     String
  role         String   @default("TEAM") // 'ADMIN', 'TEAM', 'JURY'

  evaluations  Evaluation[] // Для журі
  createdAt    DateTime @default(now())
}

model Tournament {
  id             String   @id @default(uuid())
  title          String
  description    String
  status         String   @default("DRAFT")
  
  startDate      DateTime
  regEndDate     DateTime

  teams          Team[]
  tasks          Task[]
  events         Event[]  // <--- ДОДАЙ ОСЬ ЦЕЙ РЯДОК!
}

model Team {
  id              String   @id @default(uuid())
  name            String
  tournamentId    String
  captainEmail    String
  captainName     String
  
  organization    String?  // Місто/школа
  socialLink      String?  // Telegram/Discord
  
  tournament      Tournament @relation(fields: [tournamentId], references: [id])
  members         TeamMember[] // Список учасників
  submissions     Submission[]

  createdAt      DateTime @default(now())

  // Захист від дублювання назви команди в одному турнірі
  @@unique([tournamentId, name])
  // Захист від дублювання капітана
  @@unique([tournamentId, captainEmail])
}

model TeamMember {
  id        String @id @default(uuid())
  teamId    String
  fullName  String
  email     String
  
  team      Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  // Email має бути унікальним в межах однієї команди (вимога ТЗ)
  @@unique([teamId, email])
}

model Task {
  id                String   @id @default(uuid())
  tournamentId      String
  title             String
  description       String   // Функціонал
  techRequirements  String   // Стек, БД, деплой
  mustHaveChecklist String   @default("[]") // JSON масив вимог
  
  status            String   @default("DRAFT") // DRAFT, ACTIVE, CLOSED, EVALUATED
  startTime         DateTime
  deadline          DateTime
  materialsUrl      String?  // Посилання на доп. матеріали
  
  tournament        Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  submissions       Submission[]
}

model Submission {
  id              String   @id @default(uuid())
  teamId          String
  taskId          String
  
  githubUrl       String
  videoUrl        String   // Посилання на YouTube/Drive
  liveDemoUrl     String?  // Опціонально
  description     String?  // 1-2 абзаци про проєкт
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  team            Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  task            Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  evaluations     Evaluation[]

  // Одна команда може здати лише одну роботу на одне завдання
  @@unique([teamId, taskId]) 
}

model Evaluation {
  id              String   @id @default(uuid())
  submissionId    String
  juryId          String
  
  // I. Технічна частина (0-100)
  scoreBackend    Int?
  scoreDB         Int?
  scoreFrontend   Int?

  // II. Функціональність (0-100)
  scoreMustHave   Int?
  scoreStability  Int? // Відсутність багів
  scoreUX         Int?

  comment         String?
  totalScore      Float?   // Вираховується автоматично
  status          String   @default("PENDING") // PENDING, COMPLETED

  submission      Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  jury            User       @relation(fields: [juryId], references: [id], onDelete: Cascade)

  @@unique([submissionId, juryId]) 
}

// Додай цю таблицю в кінець файлу schema.prisma
model Event {
  id           String   @id @default(uuid())
  tournamentId String
  title        String
  description  String?
  type         String   @default("MILESTONE") // MILESTONE, DEADLINE, MEETING, TASK
  date         DateTime
  
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
}