generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql" // PostgreSQL ідеально підходить для цього
  url      = env("DATABASE_URL")
}

// --- ЕНУМЕРАТОРИ ---
enum Role {
  HEAD_TEACHER // Керівник / Директор
  TEACHER      // Вчитель
  STUDENT      // Учень
}

enum Attendance {
  PRESENT
  ABSENT      // Відсутній
  LATE        // Запізнення
}

// --- КОРИСТУВАЧІ ТА КЛАСИ ---
model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  firstName    String
  lastName     String
  role         Role

  // Для учнів: прив'язка до класу (наприклад, "10-А")
  classId      String?
  class        Class?   @relation(fields: [classId], references: [id])

  // Зв'язки
  taughtSubjects    TeacherSubject[] // Для вчителів
  enrolledSubjects  StudentSubject[] // Для учнів
  givenGrades       Gradebook[]      @relation("TeacherGrades")
  receivedGrades    Gradebook[]      @relation("StudentGrades")
  achievements      Achievement[]    // ** Бонус: Досягнення

  createdAt    DateTime @default(now())
}

model Class {
  id       String   @id @default(uuid())
  name     String   @unique // Наприклад "10-А", "11-Б"
  students User[]   // Учні цього класу
  schedule Schedule[]
}

// --- ПРЕДМЕТИ ---
model Subject {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?

  teachers    TeacherSubject[]
  students    StudentSubject[]
  grades      Gradebook[]
  schedule    Schedule[]
  materials   Material[] // ** Бонус: Навчальні матеріали
  quizzes     Quiz[]     // ** Бонус: Тести
}

// Зв'язок "Вчитель - Предмет" (Хто що викладає)
model TeacherSubject {
  id        String  @id @default(uuid())
  teacherId String
  subjectId String

  teacher   User    @relation(fields: [teacherId], references: [id])
  subject   Subject @relation(fields: [subjectId], references: [id])

  @@unique([teacherId, subjectId])
}

// Зв'язок "Учень - Предмет" (Хто що вивчає)
model StudentSubject {
  id        String  @id @default(uuid())
  studentId String
  subjectId String

  student   User    @relation(fields: [studentId], references: [id])
  subject   Subject @relation(fields: [subjectId], references: [id])

  @@unique([studentId, subjectId])
}

// --- ЖУРНАЛ ОЦІНОК ТА ВІДВІДУВАНІСТЬ ---
model Gradebook {
  id          String     @id @default(uuid())
  studentId   String
  teacherId   String
  subjectId   String
  date        DateTime   // Дата уроку
  
  grade       Int?       // Оцінка (може бути null, якщо просто відсутній)
  attendance  Attendance @default(PRESENT) // Присутність/Відсутність/Запізнення

  student     User       @relation("StudentGrades", fields: [studentId], references: [id])
  teacher     User       @relation("TeacherGrades", fields: [teacherId], references: [id])
  subject     Subject    @relation(fields: [subjectId], references: [id])

  @@unique([studentId, subjectId, date]) // Один запис на учня по предмету в один день
}

// --- РОЗКЛАД (КАЛЕНДАР) ---
model Schedule {
  id          String   @id @default(uuid())
  classId     String
  subjectId   String
  startTime   DateTime
  endTime     DateTime

  class       Class    @relation(fields: [classId], references: [id])
  subject     Subject  @relation(fields: [subjectId], references: [id])
}

// ==========================================
// БОНУСНІ СУТНОСТІ (Для додаткових балів **)
// ==========================================

model Achievement {
  id          String   @id @default(uuid())
  userId      String
  title       String   // "Переможець олімпіади з математики"
  date        DateTime
  user        User     @relation(fields: [userId], references: [id])
}

model Material {
  id          String   @id @default(uuid())
  subjectId   String
  title       String
  type        String   // "PDF", "VIDEO", "WORD"
  url         String   // Посилання на файл чи відео
  subject     Subject  @relation(fields: [subjectId], references: [id])
}

model Quiz {
  id          String     @id @default(uuid())
  subjectId   String
  title       String
  subject     Subject    @relation(fields: [subjectId], references: [id])
  questions   Question[]
}

model Question {
  id          String   @id @default(uuid())
  quizId      String
  text        String
  isMultiple  Boolean  // Чи кілька правильних відповідей
  quiz        Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  answers     Answer[]
}

model Answer {
  id          String   @id @default(uuid())
  questionId  String
  text        String
  isCorrect   Boolean
  question    Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
}